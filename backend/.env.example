PORT=5000
MONGODB_URI=mongodb://localhost:27017/xoxo-travels

# Generate secrets with: openssl rand -hex 32
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRE=7d
REFRESH_TOKEN_SECRET=change_this_refresh_secret_too
REFRESH_TOKEN_EXPIRE=30d
CLIENT_URL=http://localhost:3000
ALLOWED_ORIGINS=
NODE_ENV=development
TRUST_PROXY=false
LOG_LEVEL=debug

# Amadeus (flights, hotels, activities) — leave empty for mock providers
AMADEUS_API_KEY=
AMADEUS_API_SECRET=
AMADEUS_ENV=test

# Google Maps (server-side places proxy)
GOOGLE_MAPS_API_KEY=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
ANTHROPIC_API_KEY=

# Email — Resend preferred
RESEND_API_KEY=
EMAIL_FROM=XOXO Travels <noreply@xoxo.travel>
SUPPORT_EMAIL=support@xoxo.travel
VISA_DESK_EMAIL=visa@xoxo.travel
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
