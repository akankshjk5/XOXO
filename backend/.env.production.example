# Production environment template for XOXO Travels API
# Copy to .env and fill in values before deploying

NODE_ENV=production
PORT=5000
TRUST_PROXY=true

# Frontend origin (HTTPS in production)
CLIENT_URL=https://xoxo.travel
ALLOWED_ORIGINS=https://www.xoxo.travel

# MongoDB Atlas
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/xoxo-travels?retryWrites=true&w=majority
MONGODB_URI=

# JWT — use openssl rand -hex 32 for each secret
JWT_SECRET=
JWT_EXPIRE=7d
REFRESH_TOKEN_SECRET=
REFRESH_TOKEN_EXPIRE=30d

# Amadeus (flights, hotels, activities)
AMADEUS_API_KEY=
AMADEUS_API_SECRET=
AMADEUS_ENV=test

# Google Maps / Places (server-side proxy)
GOOGLE_MAPS_API_KEY=

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Razorpay (live mode)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Anthropic (AI planner)
ANTHROPIC_API_KEY=

# Email — Resend preferred; SMTP fallback
RESEND_API_KEY=
EMAIL_FROM=XOXO Travels <noreply@xoxo.travel>
SUPPORT_EMAIL=support@xoxo.travel
VISA_DESK_EMAIL=visa@xoxo.travel

# SMTP fallback
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASS=

# Logging
LOG_LEVEL=info
