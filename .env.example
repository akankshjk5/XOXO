# XOXO.TRAVEL — Frontend environment variables
# Copy to .env.local for local development. Set in Vercel Dashboard for production.

# ── Required ──────────────────────────────────────────────────────────────────

# Backend API (include /api suffix)
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# Socket.io server (no /api suffix)
NEXT_PUBLIC_SOCKET_URL=http://localhost:5000

# Public app URL (used for OG links, redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Payments (optional — demo mode works without) ─────────────────────────────

NEXT_PUBLIC_RAZORPAY_KEY_ID=

# ── Maps (optional — server proxies places API) ─────────────────────────────

NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# ── Supabase (optional — middleware skips if unset) ─────────────────────────

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Server-only (Next.js API routes — do NOT prefix with NEXT_PUBLIC_) ────────

# Only needed if using Supabase server features
SUPABASE_SERVICE_ROLE_KEY=

# Only needed for Next.js-side AI routes (backend handles AI in production)
ANTHROPIC_API_KEY=

# Legacy — backend handles payments; keep empty on frontend
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Email — backend handles; keep empty on frontend unless using Next API routes
RESEND_API_KEY=
